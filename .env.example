APP_NAME=FollowThru
APP_ENV=development
APP_VERSION=1.0.0
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5433/followthru
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Optional Slack integration
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=
SLACK_PUBLISH_DRAFTS=true

# Optional AI extraction and chat
# Leave provider keys empty to use deterministic extraction and chat guidance.
LLM_PROVIDER=gemini
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_API_KEY=
LLM_MODEL=gemini-2.5-flash
LLM_TIMEOUT_SECONDS=30

# Backward-compatible aliases remain supported:
# SUPABASE_DB_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/followthru
# LLM_API_KEY=
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_TIMEOUT_SECONDS=30
