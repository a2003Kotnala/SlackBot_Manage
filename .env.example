APP_NAME=FollowThru
APP_ENV=development
APP_VERSION=1.0.0
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5433/followthru
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Optional Slack integration
# SLACK_BOT_TOKEN=xoxb-10718796021538-10780920892032-fc09v5n1F1iG46zFstttt0Fq
# SLACK_SIGNING_SECRET=cb191816e2caf31644b073552b7b739b
# SLACK_APP_TOKEN=xapp-1-A0ANHFP64C9-10752701273986-7000c6815b7b0d6958241e99f0e5e7459123c8903ad81e88676530af229d96c1
# SLACK_PUBLISH_DRAFTS=true

# Optional AI extraction and chat
# Leave provider keys empty to use deterministic extraction and chat guidance.
# FollowThru keeps Gemini/OpenAI-compatible fallback behavior and uses whichever
# compatible key/config is available.
LLM_PROVIDER=gemini
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_API_KEY=
LLM_MODEL=gemini-2.5-flash
LLM_TIMEOUT_SECONDS=30

# Optional transcription overrides. By default these reuse the LLM settings above.
# TRANSCRIPTION_BASE_URL=
# TRANSCRIPTION_API_KEY=
# TRANSCRIPTION_MODEL=

# Async ingestion / media processing
FOLLOWTHRU_JOB_EXECUTION_MODE=threaded
FOLLOWTHRU_MAX_JOB_RETRIES=2
FOLLOWTHRU_DOWNLOAD_TIMEOUT_SECONDS=45
FOLLOWTHRU_MAX_DOWNLOAD_BYTES=250000000
FFMPEG_BINARY=ffmpeg
FFPROBE_BINARY=ffprobe

# Backward-compatible aliases remain supported:
# SUPABASE_DB_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/followthru
# LLM_API_KEY=
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_TIMEOUT_SECONDS=30
