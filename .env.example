APP_NAME=ZManage
APP_ENV=development
APP_VERSION=1.0.0
LOG_LEVEL=INFO

DATABASE_URL=sqlite:///./zmanage.db
# Optional production database
# SUPABASE_DB_URL=postgresql://postgres.your-project-ref:your-db-password@aws-0-region.pooler.supabase.com:5432/postgres

# Optional Slack integration
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=
SLACK_PUBLISH_DRAFTS=false

# Optional AI extraction
# Leave GEMINI_API_KEY empty to use deterministic rule-based extraction only.
LLM_PROVIDER=gemini
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_API_KEY=AIzaSyCqYowhdIMn3vZpynOXjxx4KXvvp8NLp_8
LLM_MODEL=gemini-2.5-flash
LLM_TIMEOUT_SECONDS=30

# Backward-compatible aliases still supported:
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_TIMEOUT_SECONDS=30
